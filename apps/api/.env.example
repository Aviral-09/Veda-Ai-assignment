# Server
PORT=4000
CORS_ORIGIN=http://localhost:3000

# Infra mode:
#   docker  -> real MongoDB + Redis/BullMQ (run `pnpm infra:up` first)
#   memory  -> in-memory MongoDB + inline queue (no external services needed)
INFRA_MODE=docker

# Data stores (match docker-compose.yml)
MONGODB_URI=mongodb://localhost:27017/vedaai
REDIS_URL=redis://localhost:6379

# Gemini — leave GEMINI_API_KEY empty to use the built-in mock generator
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash
